# Vite client env. Copy to .env.local for local development; set the same two
# values in Vercel project env (the Supabase integration only auto-populates
# the non-VITE-prefixed names, so these two need to be added by hand).
#
# Both values are public-by-design — the anon key is intended to be exposed in
# the browser bundle. RLS policies on the Supabase tables are what actually
# protect the data.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
