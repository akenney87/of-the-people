# Of the People — server-side environment variables
#
# Copy this file to `.env` and fill in real values. .env is gitignored.
# When the project migrates to Supabase + Vercel (plan Phase 2) most of
# these go away — only the LLM and email-provider keys remain.

# --- HTTP / CORS / runtime --------------------------------------------------
# Comma-separated list of origins allowed to call the API with credentials.
# Phase 2a tightened CORS from `*` to this allowlist + credentials:true so the
# browser can send the new httpOnly auth cookies. For Vercel preview deploys
# you'll add the preview URL pattern (or use a regex; see server.js).
CLIENT_URLS=http://localhost:5173

# Set to "production" on a real deploy to flip cookie Secure flag on.
# NODE_ENV=production

# Optional override for the spawned Python interpreter used by
# /api/representatives -> districts/find_district.py. Defaults to the
# legacy Windows path in server.js; on Mac/Linux set this to /usr/bin/python3.
# PYTHON_PATH=/usr/bin/python3

# --- Postgres (server.js / Pool) ---------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=otp
DB_PASSWORD=changeme
DB_NAME=otp

# --- Auth tokens (server.js / jsonwebtoken) ---------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- Email (server.js / nodemailer, Gmail SMTP) -----------------------------
# Use a Gmail App Password, not your real password.
# Phase 2 replaces this with Resend or a Supabase Auth SMTP override.
EMAIL_USER=
EMAIL_PASS=

# --- External data APIs -----------------------------------------------------
# OpenStates v3 (state legislator metadata; used by districts/update_representatives.py)
OPENSTATES_API_KEY=

# Congress.gov v3 (federal members; currently unused — fetchFederalRepresentatives
# is dead code in server.js). Safe to leave blank.
CONGRESS_API_KEY=

# Google Civic Information API. DEPRECATED — Google sunset this API in April 2025.
# The /api/civic-info route returns errors. Leave blank.
GOOGLE_CIVIC_API_KEY=

# OpenAI (only used by districts/test_openai.py and a commented-out branch in
# generate_rep_votes.py). The blue-check inference pipeline (plan Phase 3) will
# use Anthropic Claude via Supabase Edge Functions — env var will move there.
OPENAI_API_KEY=
